# Mock SISPL responder configuration
# Values below were derived from:
# /Users/cabutchei/Documents/vs_code/caixa/silce-compra-processamento/.env

SISPL_MQ_HOST=localhost
SISPL_MQ_PORT=1414
SISPL_MQ_QUEUE_MANAGER=BRD3
SISPL_MQ_CHANNEL=BRD3.SVRCONN.SILCE
SISPL_MQ_USER=SLCEBD01
SISPL_MQ_PASSWORD=SLCEBD01

SISPL_REQUEST_QUEUE=LQ.REQ.SISPLC.BUSCA_PARAMETROS
SISPL_RESPONSE_QUEUE=LQ.RSP.SISPL.BUSCA_PARAMETROS
SISPL_PREFER_REPLY_TO=true
SISPL_POLL_WAIT_MS=5000
SISPL_RECONNECT_DELAY_MS=5000
SISPL_RUN_ONCE=false

SISPL_REPLY_CCSID=37
SISPL_REPLY_ENCODING=785
SISPL_TIME_ZONE=America/Sao_Paulo

SISPL_HEADER_USUARIO_SERVICO=SISPL
SISPL_HEADER_USUARIO=MOCK
SISPL_HEADER_OPERACAO=90301
SISPL_ORIGEM_RETORNO=SISPL
SISPL_MSG_RETORNO=OK
SISPL_COD_RETORNO=0
SISPL_INCLUDE_PROXIMO_CONCURSO=true

# Pick one payload source:
SISPL_JSON_FILE=/absolute/path/response.xml
# SISPL_RESPONSE_FILE=/absolute/path/response.xml
