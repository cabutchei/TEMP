@@ -122,7 +122,14 @@ public class ControlaIntegracaoCompraBean implements ControlaIntegracaoCompraLoc
 
     @TransactionAttribute(TransactionAttributeType.REQUIRED)
     private void tratarCriacao(MsgNuvemIntegracaoCompraSolicitacao solicitacao) throws Exception {
-        Apostador apostador = recuperarApostador(solicitacao.apostador); // TODO: tratar apostador inexistente
+        if (solicitacao.apostador == null) {
+            throw new IllegalStateException("Apostador vazio");
+        }
+        Apostador apostador = recuperarApostador(solicitacao.apostador);
+
+        if (apostador == null) {
+            throw new IllegalStateException("Não foi encontrado no legado o apostador com id " + solicitacao.apostador.idLegado);
+        }
 
         Compra compraExistente = compraDAO.findByNsuData(solicitacao.compra.nsu, extrairData(solicitacao.compra.dataInicioCompra));
 
