+#!/usr/bin/env bash
+set -euo pipefail
+
+usage() {
+  cat <<'EOF'
+Usage:
+  scripts/debug/delete_compra_flow.sh --container <container> --database <database> --password <password> [--user sa] (--compra-id <id> | --id-externo <id>)
+
+Examples:
+  scripts/debug/delete_compra_flow.sh --container sqlserver --database SILCE --password 'Secret123' --compra-id 12345
+  scripts/debug/delete_compra_flow.sh --container sqlserver --database SILCE --password 'Secret123' --id-externo N000000000000000000000000000000001
+
+Notes:
+  - The script runs sqlcmd inside the SQL Server container.
+  - It deletes rows in FK-safe order and only removes the apostador, pagamento, estorno, combo, and bolao if they are no longer referenced.
+EOF
+}
+
+container=""
+database=""
+user="sa"
+password=""
+compra_id=""
+id_externo=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --container)
+      container="${2:-}"
+      shift 2
+      ;;
+    --database)
+      database="${2:-}"
+      shift 2
+      ;;
+    --user)
+      user="${2:-}"
+      shift 2
+      ;;
+    --password)
+      password="${2:-}"
+      shift 2
+      ;;
+    --compra-id)
+      compra_id="${2:-}"
+      shift 2
+      ;;
+    --id-externo)
+      id_externo="${2:-}"
+      shift 2
+      ;;
+    -h|--help)
+      usage
+      exit 0
+      ;;
+    *)
+      echo "Unknown argument: $1" >&2
+      usage >&2
+      exit 1
+      ;;
+  esac
+done
+
+if [[ -z "$container" || -z "$database" || -z "$password" ]]; then
+  usage >&2
+  exit 1
+fi
+
+if [[ -n "$compra_id" && -n "$id_externo" ]]; then
+  echo "Use only one target: --compra-id or --id-externo." >&2
+  exit 1
+fi
+
+if [[ -z "$compra_id" && -z "$id_externo" ]]; then
+  echo "You must provide --compra-id or --id-externo." >&2
+  exit 1
+fi
+
+script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+sql_file="${script_dir}/delete_compra_flow.sql"
+
+if [[ ! -f "$sql_file" ]]; then
+  echo "SQL file not found: $sql_file" >&2
+  exit 1
+fi
+
+docker exec -i \
+  -e MSSQL_DEBUG_USER="$user" \
+  -e MSSQL_DEBUG_PASSWORD="$password" \
+  -e MSSQL_DEBUG_DATABASE="$database" \
+  -e MSSQL_DEBUG_COMPRA_ID="$compra_id" \
+  -e MSSQL_DEBUG_ID_EXTERNO="$id_externo" \
+  "$container" /bin/bash -lc '
+set -euo pipefail
+if [[ -x /opt/mssql-tools18/bin/sqlcmd ]]; then
+  SQLCMD_BIN=/opt/mssql-tools18/bin/sqlcmd
+elif [[ -x /opt/mssql-tools/bin/sqlcmd ]]; then
+  SQLCMD_BIN=/opt/mssql-tools/bin/sqlcmd
+else
+  echo "sqlcmd not found inside container" >&2
+  exit 1
+fi
+
+"$SQLCMD_BIN" -C -b -S localhost \
+  -U "$MSSQL_DEBUG_USER" \
+  -P "$MSSQL_DEBUG_PASSWORD" \
+  -d "$MSSQL_DEBUG_DATABASE" \
+  -v COMPRA_ID="$MSSQL_DEBUG_COMPRA_ID" ID_EXTERNO="$MSSQL_DEBUG_ID_EXTERNO"
+' < "$sql_file"
diff --git a/scripts/debug/delete_compra_flow.sql b/scripts/debug/delete_compra_flow.sql
new file mode 100644
index 00000000..568ec6cd
--- /dev/null
+++ b/scripts/debug/delete_compra_flow.sql
@@ -0,0 +1,185 @@
+SET NOCOUNT ON;
+
+IF ('$(COMPRA_ID)' = '' AND '$(ID_EXTERNO)' = '')
+BEGIN
+    RAISERROR('Informe COMPRA_ID ou ID_EXTERNO.', 16, 1);
+    RETURN;
+END;
+
+DECLARE @CompraIdInput BIGINT = NULL;
+DECLARE @IdExternoInput NVARCHAR(100) = NULLIF('$(ID_EXTERNO)', '');
+
+IF ('$(COMPRA_ID)' <> '')
+BEGIN
+    SET @CompraIdInput = TRY_CAST('$(COMPRA_ID)' AS BIGINT);
+
+    IF (@CompraIdInput IS NULL)
+    BEGIN
+        RAISERROR('COMPRA_ID invalido.', 16, 1);
+        RETURN;
+    END;
+END;
+
+DECLARE @CompraIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @PagamentoIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @EstornoIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @ItemIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @ApostaIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @ComboIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @ReservaIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @BolaoIds TABLE (id BIGINT PRIMARY KEY);
+DECLARE @ApostadorIds TABLE (id BIGINT PRIMARY KEY);
+
+INSERT INTO @CompraIds (id)
+SELECT c.NU_COMPRA
+FROM LCE._COMPRA c
+WHERE (@CompraIdInput IS NOT NULL AND c.NU_COMPRA = @CompraIdInput)
+   OR (@IdExternoInput IS NOT NULL AND c.NU_ID_EXTERNO = @IdExternoInput);
+
+IF NOT EXISTS (SELECT 1 FROM @CompraIds)
+BEGIN
+    RAISERROR('Nenhuma compra encontrada para os parametros informados.', 16, 1);
+    RETURN;
+END;
+
+INSERT INTO @PagamentoIds (id)
+SELECT DISTINCT c.NU_PAGAMENTO
+FROM LCE._COMPRA c
+JOIN @CompraIds ci ON ci.id = c.NU_COMPRA
+WHERE c.NU_PAGAMENTO IS NOT NULL;
+
+INSERT INTO @EstornoIds (id)
+SELECT DISTINCT p.NU_ESTORNO
+FROM LCE.PAGAMENTO p
+JOIN @PagamentoIds pi ON pi.id = p.NU_PAGAMENTO
+WHERE p.NU_ESTORNO IS NOT NULL;
+
+INSERT INTO @ItemIds (id)
+SELECT ic.NU_ITEM_COMPRAVEL
+FROM LCE._ITEM_COMPRAVEL ic
+JOIN @CompraIds ci ON ci.id = ic.NU_COMPRA;
+
+INSERT INTO @ApostaIds (id)
+SELECT DISTINCT ic.NU_APOSTA
+FROM LCE._ITEM_COMPRAVEL ic
+JOIN @CompraIds ci ON ci.id = ic.NU_COMPRA
+WHERE ic.NU_APOSTA IS NOT NULL;
+
+INSERT INTO @ComboIds (id)
+SELECT DISTINCT ai.NU_COMBO
+FROM LCE._APOSTA_INDIVIDUAL ai
+JOIN @ApostaIds ap ON ap.id = ai.NU_APOSTA
+WHERE ai.NU_COMBO IS NOT NULL;
+
+INSERT INTO @ReservaIds (id)
+SELECT DISTINCT ic.NU_RESERVA_COTA_BOLAO
+FROM LCE._ITEM_COMPRAVEL ic
+JOIN @CompraIds ci ON ci.id = ic.NU_COMPRA
+WHERE ic.NU_RESERVA_COTA_BOLAO IS NOT NULL;
+
+INSERT INTO @BolaoIds (id)
+SELECT DISTINCT r.NU_BOLAO
+FROM LCE._RESERVA_COTA_BOLAO r
+JOIN @ReservaIds ri ON ri.id = r.NU_RESERVA_COTA_BOLAO
+WHERE r.NU_BOLAO IS NOT NULL;
+
+INSERT INTO @ApostadorIds (id)
+SELECT DISTINCT c.NU_APOSTADOR
+FROM LCE._COMPRA c
+JOIN @CompraIds ci ON ci.id = c.NU_COMPRA
+WHERE c.NU_APOSTADOR IS NOT NULL;
+
+SELECT 'compra' AS tipo, COUNT(*) AS quantidade FROM @CompraIds
+UNION ALL
+SELECT 'pagamento', COUNT(*) FROM @PagamentoIds
+UNION ALL
+SELECT 'estorno', COUNT(*) FROM @EstornoIds
+UNION ALL
+SELECT 'item_compravel', COUNT(*) FROM @ItemIds
+UNION ALL
+SELECT 'aposta_individual', COUNT(*) FROM @ApostaIds
+UNION ALL
+SELECT 'combo', COUNT(*) FROM @ComboIds
+UNION ALL
+SELECT 'reserva_cota_bolao', COUNT(*) FROM @ReservaIds
+UNION ALL
+SELECT 'bolao', COUNT(*) FROM @BolaoIds
+UNION ALL
+SELECT 'apostador_candidato', COUNT(*) FROM @ApostadorIds;
+
+BEGIN TRANSACTION;
+
+BEGIN TRY
+    DELETE ic
+    FROM LCE._ITEM_COMPRAVEL ic
+    JOIN @ItemIds ids ON ids.id = ic.NU_ITEM_COMPRAVEL;
+
+    DELETE c
+    FROM LCE._COMPRA c
+    JOIN @CompraIds ids ON ids.id = c.NU_COMPRA;
+
+    DELETE ai
+    FROM LCE._APOSTA_INDIVIDUAL ai
+    JOIN @ApostaIds ids ON ids.id = ai.NU_APOSTA;
+
+    DELETE cb
+    FROM LCE.COMBO cb
+    JOIN @ComboIds ids ON ids.id = cb.NU_COMBO
+    WHERE NOT EXISTS (
+        SELECT 1
+        FROM LCE._APOSTA_INDIVIDUAL ai
+        WHERE ai.NU_COMBO = cb.NU_COMBO
+    );
+
+    DELETE r
+    FROM LCE._RESERVA_COTA_BOLAO r
+    JOIN @ReservaIds ids ON ids.id = r.NU_RESERVA_COTA_BOLAO;
+
+    DELETE b
+    FROM LCE._BOLAO b
+    JOIN @BolaoIds ids ON ids.id = b.NU_BOLAO
+    WHERE NOT EXISTS (
+        SELECT 1
+        FROM LCE._RESERVA_COTA_BOLAO r
+        WHERE r.NU_BOLAO = b.NU_BOLAO
+    );
+
+    DELETE p
+    FROM LCE.PAGAMENTO p
+    JOIN @PagamentoIds ids ON ids.id = p.NU_PAGAMENTO
+    WHERE NOT EXISTS (
+        SELECT 1
+        FROM LCE._COMPRA c
+        WHERE c.NU_PAGAMENTO = p.NU_PAGAMENTO
+    );
+
+    DELETE e
+    FROM LCE.ESTORNO e
+    JOIN @EstornoIds ids ON ids.id = e.NU_ESTORNO
+    WHERE NOT EXISTS (
+        SELECT 1
+        FROM LCE.PAGAMENTO p
+        WHERE p.NU_ESTORNO = e.NU_ESTORNO
+    );
+
+    DELETE a
+    FROM LCE._APOSTADOR a
+    JOIN @ApostadorIds ids ON ids.id = a.NU_APOSTADOR
+    WHERE NOT EXISTS (
+        SELECT 1
+        FROM LCE._COMPRA c
+        WHERE c.NU_APOSTADOR = a.NU_APOSTADOR
+    );
+
+    COMMIT TRANSACTION;
+END TRY
+BEGIN CATCH
+    IF @@TRANCOUNT > 0
+    BEGIN
+        ROLLBACK TRANSACTION;
+    END;
+
+    THROW;
+END CATCH;
+
+SELECT 'Cleanup concluido.' AS resultado;
