<server description="SILCE EAR playground on Liberty">
  <featureManager>
    <feature>ejbLite-3.2</feature>
    <feature>jpa-2.2</feature>
    <feature>jdbc-4.2</feature>
    <feature>servlet-4.0</feature>
  </featureManager>

  <applicationManager autoExpand="true"/>

  <dataSource id="silceDS" jndiName="silceDS">
    <jdbcDriver libraryRef="db2Driver"/>
    <properties.db2.jcc databaseName="SILCEDB"
                        serverName="127.0.0.1"
                        portNumber="50000"
                        user="db2inst1"
                        password="YourStrongPass1!"/>
  </dataSource>

  <library id="db2Driver">
    <fileset dir="${server.config.dir}/jdbc" includes="db2jcc4.jar"/>
  </library>
</server>
